   ]
  },
  {
   "cell_type": "markdown",
   "id": "e47aa425",
   "metadata": {},
   "source": [
    "### Step 3 — Load embeddings"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "56711f91",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pickle\n",
    "import numpy as np\n",
    "\n",
    "with open(EMBEDDINGS_PKL, 'rb') as f:\n",
    "    data = pickle.load(f)\n",
    "\n",
    "# Support both a raw dict (pid -> vector) and the structured dict used by other pipeline scripts\n",
    "if isinstance(data, dict) and 'playlist_embeddings' in data:\n",
    "    playlist_embeddings = data['playlist_embeddings']\n",
    "    playlist_titles     = data.get('playlist_titles', {})\n",
    "    playlist_tracks     = data.get('playlist_tracks', {})\n",
    "else:\n",
    "    # Assume the file is directly a pid -> embedding dict\n",
    "    playlist_embeddings = data\n",
    "    playlist_titles     = {}\n",
    "    playlist_tracks     = {}\n",
    "\n",
    "embedding_matrix = np.array(list(playlist_embeddings.values()))\n",
    "pids = list(playlist_embeddings.keys())\n",
    "\n",
    "print(f\"Loaded {len(pids)} playlists, embedding dim = {embedding_matrix.shape[1]}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "21ad053c",
   "metadata": {},
   "source": [
    "### Step 4: Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1f109981",
   "metadata": {},
   "outputs": [],
   "source": [
    "NUM_CLUSTERS = 50  # single int — adjust as needed (50–200)\n",
    "\n",
    "# Subsample for clustering (DBSCAN and Spectral are memory-intensive at scale)\n",
    "CLUSTER_SAMPLE = min(50_000, len(pids))\n",
    "\n",
    "# Subsample for t-SNE (always fast at ≤5k)\n",
    "TSNE_SAMPLE = min(5_000, CLUSTER_SAMPLE)\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "cluster_idx = rng.choice(len(pids), size=CLUSTER_SAMPLE, replace=False)\n",
    "cluster_pids = [pids[i] for i in cluster_idx]\n",
    "cluster_embeddings = {pid: playlist_embeddings[pid] for pid in cluster_pids}\n",
    "\n",
    "print(f\"Clustering {CLUSTER_SAMPLE} playlists into {NUM_CLUSTERS} clusters, t-SNE on {TSNE_SAMPLE}.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4d690c45",
   "metadata": {},
   "source": [
    "### Step 5: DBSCAN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d2b0a665",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Using defaults for now\n",
    "\n",
    "DBSCAN_EPS         = 0.5\n",
    "DBSCAN_MIN_SAMPLES = 5\n",
    "\n",
    "dbscan_output = os.path.join(CLUSTERS_OUTPUT_DIR, \"dbscan_clusters.csv\")\n",
    "\n",
    "dbscan_labels = cluster_alts.dbscan(\n",
    "    playlist_embeddings=cluster_embeddings,\n",
    "    playlist_titles=playlist_titles,\n",
    "    playlist_tracks=playlist_tracks,\n",
    "    output_file=dbscan_output,\n",
    "    eps=DBSCAN_EPS,\n",
    "    min_samples=DBSCAN_MIN_SAMPLES,\n",
    ")\n",
    "\n",
    "n_found = len(set(dbscan_labels)) - (1 if -1 in dbscan_labels else 0)\n",
    "n_noise = (dbscan_labels == -1).sum()\n",
    "print(f\"DBSCAN done: {n_found} clusters, {n_noise} noise points. Results saved to {dbscan_output}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "7f7e0343",
   "metadata": {},
   "source": [
    "### Step 6: Gaussian Mixture Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d7b6c6c4",
   "metadata": {},
   "outputs": [],
   "source": [
    "gaussianmix_output = os.path.join(CLUSTERS_OUTPUT_DIR, \"gaussianmix_clusters.csv\")\n",
    "\n",
    "gaussianmix_labels = cluster_alts.gaussianmix(\n",
    "    playlist_embeddings=cluster_embeddings,\n",
    "    num_clusters=NUM_CLUSTERS,\n",
    "    playlist_titles=playlist_titles,\n",
    "    playlist_tracks=playlist_tracks,\n",
    "    output_file=gaussianmix_output,\n",
    ")\n",
    "\n",
    "print(f\"Gaussian Mixture done. Results saved to {gaussianmix_output}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "24cbfe18",
   "metadata": {},
   "source": [
    "### Step 7: Fuzzy K-Means"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "9fc6ce31",
   "metadata": {},
   "outputs": [],
   "source": [
    "fkmeans_output = os.path.join(CLUSTERS_OUTPUT_DIR, \"fkmeans_clusters.csv\")\n",
    "\n",
    "fkmeans_labels = cluster_alts.fkmeans(\n",
    "    playlist_embeddings=cluster_embeddings,\n",
    "    num_clusters=NUM_CLUSTERS,\n",
    "    playlist_titles=playlist_titles,\n",
    "    playlist_tracks=playlist_tracks,\n",
    "    output_file=fkmeans_output,\n",
    ")\n",
    "\n",
    "print(f\"Fuzzy K-Means done. Results saved to {fkmeans_output}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "652ad043",
   "metadata": {},
   "source": [
    "### Step 8: t-SNE"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "45585baa",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.manifold import TSNE\n",
    "import numpy as np\n",
    "\n",
    "# cluster_embeddings is already a subsample; take TSNE_SAMPLE from it for t-SNE\n",
    "cluster_matrix = np.array(list(cluster_embeddings.values()), dtype=np.float32)\n",
    "rng_tsne = np.random.default_rng(0)\n",
    "tsne_local_idx = rng_tsne.choice(len(cluster_matrix), size=TSNE_SAMPLE, replace=False)\n",
    "sample_matrix = cluster_matrix[tsne_local_idx]\n",
    "\n",
    "print(f\"Running t-SNE on {TSNE_SAMPLE} samples...\")\n",
    "tsne = TSNE(n_components=2, perplexity=30, random_state=42, n_jobs=-1)\n",
    "tsne_coords = tsne.fit_transform(sample_matrix)\n",
    "print(\"t-SNE complete.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "475291b0",
   "metadata": {},
   "source": [
    "### Step 9: Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f3595139",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.cm as cm\n",
    "\n",
    "methods = {\n",
    "    \"Fuzzy K-Means\":    fkmeans_labels[tsne_local_idx],\n",
    "    \"DBSCAN\":           dbscan_labels[tsne_local_idx],\n",
    "    \"Gaussian Mixture\": gaussianmix_labels[tsne_local_idx],\n",
    "}\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(20, 6))\n",
    "\n",
    "for ax, (title, labels) in zip(axes, methods.items()):\n",
    "    unique_labels = np.unique(labels)\n",
    "    cmap = cm.get_cmap('tab20', max(len(unique_labels), 1))\n",
    "    colors = np.array([cmap(np.where(unique_labels == l)[0][0]) if l != -1 else (0.7, 0.7, 0.7, 1.0)\n",
    "                       for l in labels])\n",
    "    ax.scatter(tsne_coords[:, 0], tsne_coords[:, 1],\n",
    "               c=colors, s=4, alpha=0.6, linewidths=0)\n",
    "    ax.set_title(title, fontsize=13, fontweight='bold')\n",
    "    ax.set_xlabel(\"t-SNE 1\")\n",
    "    ax.set_ylabel(\"t-SNE 2\")\n",
    "    ax.set_xticks([])\n",
    "    ax.set_yticks([])\n",
    "\n",
    "fig.suptitle(f\"Clustering Comparison — {NUM_CLUSTERS} clusters, n={CLUSTER_SAMPLE}\",\n",
    "             fontsize=15, fontweight='bold')\n",
    "plt.tight_layout()\n",
    "plt.savefig(os.path.join(CLUSTERS_OUTPUT_DIR, \"clustering_comparison_tsne.png\"), dpi=150)\n",
    "plt.show()\n",
    "print(\"Plot saved.\")"
   ]
  },
