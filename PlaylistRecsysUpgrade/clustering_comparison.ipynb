      },
      "source": [
        "### Step 3 — Load embeddings"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 6,
      "id": "56711f91",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "56711f91",
        "outputId": "1982b5a8-f45f-4c80-de5b-ea494a9cc73f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Loaded 1000001 playlists, embedding dim = 768\n"
          ]
        }
      ],
      "source": [
        "import pickle\n",
        "import numpy as np\n",
        "\n",
        "with open(EMBEDDINGS_PKL, 'rb') as f:\n",
        "    data = pickle.load(f)\n",
        "\n",
        "# Support both a raw dict (pid -> vector) and the structured dict used by other pipeline scripts\n",
        "if isinstance(data, dict) and 'playlist_embeddings' in data:\n",
        "    playlist_embeddings = data['playlist_embeddings']\n",
        "    playlist_titles     = data.get('playlist_titles', {})\n",
        "    playlist_tracks     = data.get('playlist_tracks', {})\n",
        "else:\n",
        "    # Assume the file is directly a pid -> embedding dict\n",
        "    playlist_embeddings = data\n",
        "    playlist_titles     = {}\n",
        "    playlist_tracks     = {}\n",
        "\n",
        "embedding_matrix = np.array(list(playlist_embeddings.values()))\n",
        "pids = list(playlist_embeddings.keys())\n",
        "\n",
        "print(f\"Loaded {len(pids)} playlists, embedding dim = {embedding_matrix.shape[1]}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "21ad053c",
      "metadata": {
        "id": "21ad053c"
      },
      "source": [
        "### Step 4: Configuration"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 7,
      "id": "1f109981",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1f109981",
        "outputId": "d1e4437c-87ea-4eaf-8f20-0febcc03b87f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Sampling data for faster clustering...\n",
            "Clustering into 50 clusters (using the first value from NUM_CLUSTERS list) on a sample of 50000 playlists.\n",
            "t-SNE on 5000 playlists.\n"
          ]
        }
      ],
      "source": [
        "import random\n",
        "import numpy as np\n",
        "\n",
        "NUM_CLUSTERS = [50, 100, 200]\n",
        "\n",
        "CLUSTER_SAMPLE = min(50_000, len(pids))\n",
        "\n",
        "print(\"Sampling data for faster clustering...\")\n",
        "random.seed(42)\n",
        "sampled_pids = random.sample(pids, CLUSTER_SAMPLE)\n",
        "\n",
        "sampled_playlist_embeddings = {pid: playlist_embeddings[pid] for pid in sampled_pids}\n",
        "sampled_playlist_titles = {pid: playlist_titles.get(pid, \"\") for pid in sampled_pids}\n",
        "sampled_playlist_tracks = {pid: playlist_tracks.get(pid, []) for pid in sampled_pids}\n",
        "\n",
        "sampled_embedding_matrix = np.array([sampled_playlist_embeddings[pid] for pid in sampled_pids])\n",
        "\n",
        "# t-SNE sample size — reduce if the full dataset is too large\n",
        "TSNE_SAMPLE = min(5000, len(sampled_pids))\n",
        "\n",
        "print(f\"Clustering into {NUM_CLUSTERS[2]} clusters (using the first value from NUM_CLUSTERS list) on a sample of {CLUSTER_SAMPLE} playlists.\\nt-SNE on {TSNE_SAMPLE} playlists.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "24cbfe18",
      "metadata": {
        "id": "24cbfe18"
      },
      "source": [
        "### Step 7: Fuzzy K-Means"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 17,
      "id": "9fc6ce31",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "9fc6ce31",
        "outputId": "55dcbf1c-6272-499e-be4d-7a70616af88a"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Fitting Fuzzy K-Means...\n",
            "Fuzzy K-Means done. Results saved to /content/drive/MyDrive/S2026/CS 274/Playlist-Recommender/new clusters/fkmeans_clusters.csv\n"
          ]
        }
      ],
      "source": [
        "import pandas as pd\n",
        "from skfuzzy import cmeans\n",
        "\n",
        "fkmeans_output = os.path.join(CLUSTERS_OUTPUT_DIR, \"fkmeans_clusters.csv\")\n",
        "\n",
        "print(\"Fitting Fuzzy K-Means...\")\n",
        "fkm_result = cmeans(embedding_matrix.T, NUM_CLUSTERS[1], 2, error=0.005, maxiter=1000)\n",
        "fkmeans_labels = np.argmax(fkm_result[1], axis=0)\n",
        "\n",
        "pd.DataFrame({\n",
        "    'pid': pids,\n",
        "    'cluster': fkmeans_labels\n",
        "}).to_csv(fkmeans_output, index=False)\n",
        "\n",
        "print(f\"Fuzzy K-Means done. Results saved to {fkmeans_output}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "652ad043",
      "metadata": {
        "id": "652ad043"
      },
      "source": [
        "### Step 8: t-SNE"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 18,
      "id": "45585baa",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "45585baa",
        "outputId": "d4d145cb-f7cd-49d9-ec0b-35d92c125101"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Running t-SNE on 20000 sampled playlists...\n",
            "t-SNE complete.\n"
          ]
        }
      ],
      "source": [
        "from sklearn.manifold import TSNE\n",
        "import numpy as np\n",
        "\n",
        "# To keep complexity low for visualization, we will run t-SNE on a sample.\n",
        "# The clustering (e.g., Fuzzy K-Means) is still performed on the full dataset.\n",
        "\n",
        "# Use the sampled_embedding_matrix for t-SNE visualization\n",
        "# sample_idx should be generated here to correspond to the points actually used for t-SNE\n",
        "rng = np.random.default_rng(42)\n",
        "sample_idx_tsne = rng.choice(len(pids), size=20000, replace=False)\n",
        "tsne_input_matrix = embedding_matrix[sample_idx_tsne]\n",
        "tsne_data_size = 20000\n",
        "\n",
        "print(f\"Running t-SNE on {tsne_data_size} sampled playlists...\")\n",
        "# n_jobs=-1 uses all available CPU cores\n",
        "tsne = TSNE(n_components=2, perplexity=30, random_state=42, n_jobs=-1)\n",
        "tsne_coords = tsne.fit_transform(tsne_input_matrix)\n",
        "print(\"t-SNE complete.\")\n",
        "\n",
        "# The sample_idx for plotting should now reference the original position of the sampled data\n",
        "# This means we need the labels corresponding to the sampled PIDs used for t-SNE\n",
        "# For fkmeans, we ran it on the full data, so we need to map those full labels to our t-SNE sample.\n",
        "# However, it's simpler to just ensure fkmeans_labels are consistent with sampled_pids,\n",
        "# or re-run fkmeans on sampled_embedding_matrix if we want a 1:1 visualization of sampled clusters.\n",
        "# For now, let's keep fkmeans_labels from the full dataset and pick the relevant ones for the t-SNE sample.\n"
      ]
    },
    {
      "cell_type": "markdown",
      "id": "475291b0",
      "metadata": {
        "id": "475291b0"
      },
      "source": [
        "### Step 9: Visualization"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 19,
      "id": "f3595139",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/",
          "height": 627
        },
        "id": "f3595139",
        "outputId": "3afc8faa-9e37-4355-d365-d6b339bacf04"
      },
      "outputs": [
        {
          "output_type": "display_data",
          "data": {
            "text/plain": [
              "<Figure size 800x600 with 1 Axes>"
            ],
            "image/png": "\n"
          },
          "metadata": {}
        },
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Plot saved.\n"
          ]
        }
      ],
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import numpy as np\n",
        "import os\n",
        "\n",
        "# Simplify label mapping: directly index the original labels array with the t-SNE sample indices\n",
        "fkmeans_labels_for_tsne_sample = fkmeans_labels[sample_idx_tsne]\n",
        "\n",
        "methods = {\n",
        "    \"Fuzzy K-Means\": fkmeans_labels_for_tsne_sample,\n",
        "}\n",
        "\n",
        "fig, ax = plt.subplots(1, 1, figsize=(8, 6))\n",
        "\n",
        "# Extract the single method and its labels\n",
        "title, labels = list(methods.items())[0]\n",
        "\n",
        "# Separate noise points (for DBSCAN compatibility, though fkmeans doesn't output -1)\n",
        "noise_mask = (labels == -1)\n",
        "cluster_mask = (labels != -1)\n",
        "\n",
        "# Plot noise as grey\n",
        "if noise_mask.any():\n",
        "    ax.scatter(tsne_coords[noise_mask, 0], tsne_coords[noise_mask, 1],\n",
        "               c='lightgrey', s=4, alpha=0.6, linewidths=0, label='Noise')\n",
        "\n",
        "# Plot actual clusters using a continuous colormap ('turbo') that handles many clusters better than 'tab20'\n",
        "ax.scatter(tsne_coords[cluster_mask, 0], tsne_coords[cluster_mask, 1],\n",
        "           c=labels[cluster_mask], cmap='turbo', s=4, alpha=0.6, linewidths=0)\n",
        "\n",
        "ax.set_title(title, fontsize=13, fontweight='bold')\n",
        "ax.set_xlabel(\"t-SNE 1\")\n",
        "ax.set_ylabel(\"t-SNE 2\")\n",
        "ax.set_xticks([])\n",
        "ax.set_yticks([])\n",
        "\n",
        "fig.suptitle(f\"{title} Clustering — {NUM_CLUSTERS[1]} clusters\",\n",
        "             fontsize=15, fontweight='bold')\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(CLUSTERS_OUTPUT_DIR, \"clustering_comparison_tsne.png\"), dpi=150)\n",
        "plt.show()\n",
        "print(\"Plot saved.\")"
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "590185e0",
        "outputId": "19d955ab-bb69-474a-e1ff-1eb97d70bd6c"
