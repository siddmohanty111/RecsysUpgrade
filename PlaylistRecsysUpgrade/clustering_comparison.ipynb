        "EMBEDDINGS_PKL       = f\"{DRIVE_BASE}/mean_pooled_embeddings.pkl\"\n",
        "CLUSTERS_OUTPUT_DIR  = f\"{PROJECT_BASE}/new clusters\"\n",
        "REPO_DIR             = \"/content/RecsysUpgrade\"\n",
        "\n",
        "import os\n",
        "os.makedirs(CLUSTERS_OUTPUT_DIR, exist_ok=True)\n",
        "print(\"Paths configured.\")"
      ]
    },
